# -----------------------------------------------------------------------------
# Cart-It server environment (copy to `.env` and fill in real values)
#
# HOW THIS FILE MAPS TO THE CODE (for students)
#   - `db.ts` reads DATABASE_URL to build the Postgres pool.
#   - `index.ts` reads JWT_SECRET to sign/verify login tokens and password-reset tokens.
#   - Email-related routes read RESEND_* and FRONTEND_URL when sending links.
# -----------------------------------------------------------------------------

# Local Postgres (create DB first — see server/scripts/create_database_cart_it.sql)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/cart_it

# Neon / Render / any Postgres provider: full connection string the `pg` library understands.
DATABASE_URL=your_neon_database_url_here

# Port the Express server listens on (your React app’s `api.js` must point at the same port in dev).
PORT=5001

# Secret key for JWT — long random string in real life. Never commit the real `.env` to Git.
JWT_SECRET=...

# Base URL of the React site. Used to build links in emails (password reset, invites). Must match where users open the app.
FRONTEND_URL=https://cart-it.pages.dev

# Optional: log POST /api/cart-items bodies to Render logs (set to 1 while debugging the extension).
# DEBUG_CART_POST=1

# Resend (https://resend.com): API sends transactional email through their HTTP API. Leave blank locally if you skip email tests.
RESEND_API_KEY=

# "From" address Resend accepts for your domain (example uses their onboarding sender).
RESEND_FROM_EMAIL=Cart-It <onboarding@resend.dev>

# How long password-reset links stay valid (minutes).
RESET_PASSWORD_EXP_MINUTES=30

# Background job that re-fetches product pages for price/stock. Can be noisy offline — disable for class demos:
# PRICE_CHECK_ENABLED=false
# Or: PRICE_CHECK_INTERVAL_MINUTES=0
# When enabled, changes can create in-app notifications; emails need RESEND_API_KEY + RESEND_FROM_EMAIL.
