{
  "manifest_version": 3,
  "name": "Cart-It Save",
  "version": "1.0.0",
  "description": "Save the current product page to your Cart-It wishlist.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save to Cart-It"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"]
}
